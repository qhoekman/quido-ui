{
  "name": "quido-ui",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "host": "pnpm --filter @quido-ui/host",
    "angular": "pnpm --filter @quido-ui/angular",
    "react": "pnpm --filter @quido-ui/react",
    "vue": "pnpm --filter @quido-ui/vue",
    "build": "turbo run build",
    "generate:llms": "node scripts/generate-llms-txt.mjs --out dist --base-url https://ui.squid-ware.nl",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "rm -rf packages/*/storybook-static",
    "test:e2e": "pnpm --filter @quido-ui/e2e test",
    "test:e2e:vue": "pnpm --filter @quido-ui/e2e test:vue",
    "test:e2e:react": "pnpm --filter @quido-ui/e2e test:react",
    "test:e2e:angular": "pnpm --filter @quido-ui/e2e test:angular"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}