    { "source": "/react", "destination": "/react/index.html" },
    { "source": "/react/", "destination": "/react/index.html" },
    { "source": "/angular", "destination": "/angular/index.html" },
    { "source": "/angular/", "destination": "/angular/index.html" }
  ]
}
